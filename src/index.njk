---
layout: 'base.njk'
title: Vizt Nivlir – Asides
---

{% set heroCandidates = collections.heroImages or [] %}
{% set heroFallbackSrc = "/assets/blog/vizt_at_home_3.jpg" %}
{% set heroFallbackAlt = "Vizt at home" %}
{% if heroCandidates.length %}
  {% set heroFallbackSrc = heroCandidates[0].data.image %}
  {% set heroFallbackAlt = heroCandidates[0].data.imageAlt or heroCandidates[0].data.title or "Vizt Nivlir" %}
{% endif %}

<section class="hero">
  <div class="container hero__layout">
      <div class="hero__copy">
        <div class="hero__content flow">
          <h1 class="section-title" data-translate-es="Apartes">Asides</h1>
          <p>This is not a blog in the usual sense.</p>
        </div>
        <div class="hero__media hero__media--mobile">
          {% if heroCandidates.length %}
          <img
            src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
            alt="{{ heroFallbackAlt }}"
            class="hero__image"
            data-hero-image>
          <noscript>
            <img src="{{ heroFallbackSrc }}" alt="{{ heroFallbackAlt }}" class="hero__image is-loaded">
          </noscript>
          {% else %}
          <img src="{{ heroFallbackSrc }}" alt="{{ heroFallbackAlt }}" class="hero__image is-loaded" data-hero-image>
          {% endif %}
        </div>
        <div class="hero__body flow">
          <p>It is a collection of notes, margins, and observations made while building things that are meant to work — interfaces, systems, small pieces of order.</p>
          <p>Some entries begin as technical problems and end as reflections. Others do the opposite. Many are written while waiting for something to compile, deploy, or make sense.</p>
          <p>Nothing here is optimized for scale. Everything here is written to be read.</p>
          <p>You are welcome to browse. Linger if you like. These are asides, after all.</p>
          {# <div class="flex-group">
            <a href="#featured-articles" class="btn btn--primary">Featured articles</a>
            <a href="./blog" class="btn btn--neutral">Most recent articles</a>
          </div> #}
        </div>
      </div>
      <div class="hero__media hero__media--desktop">
        {% if heroCandidates.length %}
        <img
          src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
          alt="{{ heroFallbackAlt }}"
          class="hero__image"
          data-hero-image>
        <noscript>
          <img src="{{ heroFallbackSrc }}" alt="{{ heroFallbackAlt }}" class="hero__image is-loaded">
        </noscript>
        {% else %}
        <img src="{{ heroFallbackSrc }}" alt="{{ heroFallbackAlt }}" class="hero__image is-loaded" data-hero-image>
        {% endif %}
      </div>
  </div>
</section>

{% if heroCandidates.length %}
<script id="hero-image-options" type="application/json">
[
  {%- for post in heroCandidates -%}
    {
      "src": {{ post.data.image | json | safe }},
      "alt": {{ (post.data.imageAlt or post.data.title or "Vizt Nivlir") | json | safe }}
    }{% if not loop.last %},{% endif %}
  {%- endfor -%}
]
</script>

<script>
(function () {
  var dataEl = document.getElementById('hero-image-options');
  var heroImages = Array.prototype.slice.call(document.querySelectorAll('[data-hero-image]'));

  if (!dataEl || !heroImages.length) return;

  try {
    var images = JSON.parse(dataEl.textContent).filter(function (item) {
      return item && item.src;
    });

    if (!images.length) return;

    var storedIndex = parseInt(sessionStorage.getItem('heroImageIndex') || '0', 10);
    var currentIndex = Number.isFinite(storedIndex) ? storedIndex : 0;
    var selected = images[currentIndex % images.length];

    sessionStorage.setItem('heroImageIndex', String((currentIndex + 1) % images.length));

    heroImages.forEach(function (img) {
      img.classList.remove('is-loaded');
    });

    var preloader = new Image();

    preloader.addEventListener('load', function handleLoad() {
      heroImages.forEach(function (img) {
        img.alt = selected.alt || img.alt;
        img.src = selected.src;
        img.classList.add('is-loaded');
      });
    }, { once: true });

    preloader.addEventListener('error', function handleError() {
      heroImages.forEach(function (img) {
        img.alt = selected.alt || img.alt;
        img.src = selected.src;
        img.classList.add('is-loaded');
      });
    }, { once: true });

    preloader.src = selected.src;
  } catch (error) {
    console.warn('Unable to choose the next hero image.', error);
  }
})();
</script>
{% endif %}
 
<section id="featured-articles" class="featured-articles">
  <div class="container flow">
    <h2 class="section-title text-center" data-translate-es="Retazos del espejo">From the Stack</h2>
    <p class="text-center" data-translate-es="Trozos sueltos, ninguno fiel, pero juntos casi reflejan.">A handful of dispatches that speak, in part, for the whole.</p>
    <ul role="list" class="articles__list flow">

      {%- for post in collections.featured | reverse -%}
        {% include 'article-snippet.njk' %}
      {%- endfor -%} 

    </ul>
  </div>
</section> 
